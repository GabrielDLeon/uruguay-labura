---
import { Icon } from "astro-icon/components";
---

<header
  data-pagefind-ignore
  class="border-b border-[var(--color-border)] bg-[var(--card-bg)]/90 backdrop-blur"
>
  <div
    class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6"
  >
    <div class="flex items-center gap-4">
      <a href="/" class="text-base font-bold text-foreground sm:text-lg"
        >Uruguay Labura</a
      >

      <nav class="hidden items-center gap-1 text-sm sm:flex">
        <a
          href="/empleos"
          class="inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        >
          <Icon
            name="mdi:briefcase-outline"
            size={16}
            class="shrink-0"
            aria-hidden="true"
          />
          Empleos
        </a>
        <a
          href="/educacion"
          class="inline-flex items-center gap-1 rounded-md px-3 py-1.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        >
          <Icon
            name="mdi:school-outline"
            size={16}
            class="shrink-0"
            aria-hidden="true"
          />
          Educación
        </a>
      </nav>
    </div>

    <div class="flex items-center gap-2">
      <nav class="flex items-center gap-1 text-sm sm:hidden">
        <a
          href="/empleos"
          class="inline-flex items-center gap-1 rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        >
          <Icon
            name="mdi:briefcase-outline"
            size={16}
            class="shrink-0"
            aria-hidden="true"
          />
          Empleos
        </a>
        <a
          href="/educacion"
          class="inline-flex items-center gap-1 rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        >
          <Icon
            name="mdi:school-outline"
            size={16}
            class="shrink-0"
            aria-hidden="true"
          />
          Educación
        </a>
      </nav>

      <a
        href="https://github.com/GabrielDLeon/uruguay-labura"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub repository"
        class="btn-icon-outline size-8"
      >
        <Icon name="mdi:github" size={24} aria-hidden="true" />
      </a>

      <button
        type="button"
        aria-label="Toggle dark mode"
        data-tooltip="Toggle dark mode"
        data-side="bottom"
        onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
        class="btn-icon-outline size-8"
      >
        <span class="hidden dark:block">
          <Icon name="mdi:white-balance-sunny" size={24} aria-hidden="true" />
        </span>
        <span class="block dark:hidden">
          <Icon name="mdi:weather-night" size={24} aria-hidden="true" />
        </span>
      </button>
    </div>
  </div>
</header>
