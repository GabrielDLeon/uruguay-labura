---
import { SEO } from 'astro-seo'
import { siteConfig } from '@/config/site'

interface Props {
  title?: string
  description?: string
}

const { title = siteConfig.titleDefault, description = siteConfig.description } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString()
---

<SEO
  title={title}
  description={description}
  titleDefault={siteConfig.titleDefault}
  titleTemplate={siteConfig.titleTemplate}
  canonical={canonicalURL}
  noindex={siteConfig.robots.noindex}
  nofollow={siteConfig.robots.nofollow}
  openGraph={{
    basic: {
      title,
      type: 'website',
      image: `${Astro.site}${siteConfig.ogImage.name}`,
      url: canonicalURL,
    },
    image: {
      url: `${Astro.site}${siteConfig.ogImage.name}`,
      alt: siteConfig.ogImage.alt,
      width: siteConfig.ogImage.width,
      height: siteConfig.ogImage.height,
    },
  }}
  twitter={{
    creator: siteConfig.social.twitter,
    card: 'summary_large_image',
    title,
  }}
/>
