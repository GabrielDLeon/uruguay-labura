---
interface Props {
  label: string
  value: string
  total: number
  filled: number
}

const { label, value, total, filled } = Astro.props

const levelColors = [
  'bg-[var(--bar-l1)]',
  'bg-[var(--bar-l2)]',
  'bg-[var(--bar-l3)]',
  'bg-[var(--bar-l4)]',
]
const activeColor = levelColors[Math.min(filled - 1, levelColors.length - 1)]!
---

<div>
  <div class="flex justify-between mb-1 font-medium">
    <span class="text-muted-foreground text-sm">{label}</span>
    <span class="text-foreground text-sm">{value}</span>
  </div>
  <div class="flex gap-1">
    {
      Array.from({ length: total }, (_, i) => (
        <div
          class={`h-1.5 flex-1 rounded-full ${i < filled ? activeColor : 'bg-[var(--bar-inactive)]'}`}
        />
      ))
    }
  </div>
</div>
