---
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import { degreeTypeLabels, modalityLabels } from "@/lib/educacion";

const entries = await getCollection("educacion");

entries.sort((a, b) => a.data.title.localeCompare(b.data.title, "es"));
---

<Layout
  title="Educacion en Uruguay"
  description="Explora postgrados, maestrias, especializaciones y otras opciones de educacion superior en Uruguay."
>
  <section class="mb-8 pt-6 sm:pt-8">
    <h1 class="text-2xl mb-2 font-extrabold text-foreground sm:text-3xl">
      Educacion en Uruguay
    </h1>
    <p class="max-w-3xl text-sm sm:text-base text-muted-foreground">
      Recopilacion de postgrados, maestrias, especializaciones y otras opciones
      de formacion superior disponibles en el pais. Un lugar unico para quienes
      buscan seguir creciendo profesionalmente.
    </p>
  </section>

  <section class="overflow-x-auto">
    <table class="table table-fixed w-full min-w-[900px]">
      <colgroup>
        <col class="w-56" />
        <col class="w-32" />
        <col />
        <col class="w-28" />
        <col class="w-24" />
        <col class="w-28" />
      </colgroup>
      <thead>
        <tr>
          <th>Institucion</th>
          <th>Tipo</th>
          <th>Titulo</th>
          <th>Modalidad</th>
          <th>Duracion</th>
          <th>Accion</th>
        </tr>
      </thead>
      <tbody>
        {
          entries.map((entry) => (
            <tr>
              <td class="truncate" title={entry.data.institution}>
                {entry.data.institution}
              </td>
              <td class="truncate">
                {degreeTypeLabels[entry.data.degreeType] ??
                  entry.data.degreeType}
              </td>
              <td>
                <div class="font-semibold">
                  <a href={`/educacion/${entry.id}`} class="hover:underline">
                    {entry.data.title}
                  </a>
                </div>
                <div class="text-muted-foreground text-xs">
                  {entry.data.area}
                </div>
              </td>
              <td class="truncate">
                {modalityLabels[entry.data.modality] ?? entry.data.modality}
              </td>
              <td class="whitespace-nowrap">{entry.data.duration}</td>
              <td class="whitespace-nowrap">
                <a
                  href={`/educacion/${entry.id}`}
                  class="btn btn-sm inline-flex items-center gap-1"
                >
                  Ver mas
                </a>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>

    {
      entries.length === 0 ? (
        <p class="text-muted-foreground mt-4 text-sm">
          No hay programas registrados por el momento.
        </p>
      ) : null
    }
  </section>
</Layout>
