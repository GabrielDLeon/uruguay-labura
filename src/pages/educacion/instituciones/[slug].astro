---
import { getCollection, render } from "astro:content";

import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import { institutionTypeLabels } from "@/lib/institution";
import UruguayMap from "@/components/UruguayMap.astro";
import AsideSection from "@/components/AsideSection.astro";
import { locationsToIds } from "@/lib/departments";

export async function getStaticPaths() {
  const entries = await getCollection("institutions");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={entry.data.short ?? entry.data.name}
  description={`${entry.data.name} — ${institutionTypeLabels[entry.data.type]} university in Uruguay.`}
>
  <div class="mt-6 mb-4">
    <a
      href="/educacion/instituciones"
      class="text-sm text-muted-foreground hover:text-foreground"
    >
      ← Volver a Instituciones
    </a>
    </div>

  <div class="flex items-start gap-6 mb-8">
    {
      entry.data.logo && (
        <Image
          src={entry.data.logo}
          alt={entry.data.name}
          class="h-32 w-auto object-contain shrink-0 mt-1 rounded-lg"
        />
      )
    }
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-3">
        <span
          class={`badge ${
            entry.data.type === "public" ? "badge-success" : "badge-secondary"
          }`}
        >
          {institutionTypeLabels[entry.data.type]}
        </span>
        {
          entry.data.location ? (
            <span class="text-xs text-muted-foreground">
              {entry.data.location}
            </span>
          ) : null
        }
      </div>

      <h1 class="text-2xl mb-1 font-bold text-foreground sm:text-3xl">
        {
          entry.data.short
            ? `${entry.data.name} (${entry.data.short})`
            : entry.data.name
        }
      </h1>
      {
        entry.data.description ? (
          <p class="text-muted-foreground text-xs leading-relaxed max-w-xl">
            {entry.data.description}
          </p>
        ) : null
      }
    </div>
  </div>

  <div class="grid gap-8 md:grid-cols-3 mb-8">
    <div class="md:col-span-2 min-w-0">
      <div class="rounded-xl bg-[var(--muted)] p-6">
        <div class="prose prose-sm dark:prose-invert max-w-none">
          <Content />
        </div>
      </div>
    </div>

    <aside class="flex flex-col gap-8">
      <AsideSection title="Contacto">
        <div class="flex flex-col gap-2">
          <a
            href={entry.data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm inline-flex items-center justify-center gap-1"
          >
            Sitio oficial
          </a>
          {
            entry.data.contactEmail ? (
              <a
                href={`mailto:${entry.data.contactEmail}`}
                class="btn-sm-outline inline-flex items-center justify-center gap-1"
              >
                {entry.data.contactEmail}
              </a>
            ) : null
          }
          {
            entry.data.phone ? (
              <a
                href={`tel:${entry.data.phone}`}
                class="btn-sm-outline inline-flex items-center justify-center gap-1"
              >
                {entry.data.phone}
              </a>
            ) : null
          }
        </div>
      </AsideSection>

      <AsideSection
        title="Presencia"
        style={entry.data.color ? `--map-highlight: ${entry.data.color}` : undefined}
      >
        <UruguayMap
          highlighted={locationsToIds(entry.data.departments)}
        />
      </AsideSection>

      {
        entry.data.tags.length > 0 ? (
          <AsideSection title="Tags">
            <div class="flex flex-wrap gap-1">
              {entry.data.tags.map((tag) => (
                <span class="badge-outline text-xs">{tag}</span>
              ))}
            </div>
          </AsideSection>
        ) : null
      }
    </aside>
  </div>
</Layout>
