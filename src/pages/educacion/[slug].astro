---
import { getCollection, render } from "astro:content";

import { Icon } from "astro-icon/components";
import Layout from "@/layouts/Layout.astro";
import {
  degreeTypeLabels,
  modalityLabels,
  modalityBarFilled,
  getDegreeTypeBarInfo,
  formatDate,
  getSolidarityFundInfo,
} from "@/lib/educacion";
import SolidarityFundInfo from "@/components/SolidarityFundInfo.astro";
import BarIndicator from "@/components/BarIndicator.astro";
import AsideSection from "@/components/AsideSection.astro";
import KeyValueList from "@/components/KeyValueList.astro";

export async function getStaticPaths() {
  const entries = await getCollection(
    "educacion",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const solidarityFund = getSolidarityFundInfo(
  entry.data.institution,
  entry.data.duration,
);

const detailItems = [
  { label: "Área", value: entry.data.area },
  { label: "Duración", value: entry.data.duration },
  { label: "Créditos", value: entry.data.credits },
  { label: "Costo", value: entry.data.cost },
  { label: "Idioma", value: entry.data.language },
  { label: "Ubicación", value: entry.data.location },
  { label: "Acreditación", value: entry.data.accreditation },
  {
    label: "Inicio",
    value: entry.data.startDate ? formatDate(entry.data.startDate) : undefined,
  },
  {
    label: "Cierre inscripción",
    value: entry.data.applicationDeadline
      ? formatDate(entry.data.applicationDeadline)
      : undefined,
  },
];
---

<Layout
  title={entry.data.title}
  description={entry.data.description ??
    `${entry.data.degreeType} en ${entry.data.area} ofrecido por ${entry.data.institutionName}.`}
>
  <div class="mb-4">
    <a
      href="/educacion"
      class="text-sm text-muted-foreground hover:text-foreground"
    >
      ← Volver a Educación
    </a>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl mb-1 font-bold text-foreground sm:text-3xl">
      {entry.data.title}
    </h1>
    <p class="text-muted-foreground text-base">
      {
        entry.data.institution ? (
          <a
            href={`/educacion/instituciones/${entry.data.institution}`}
            class="hover:underline"
          >
            {entry.data.institutionName}
          </a>
        ) : (
          entry.data.institutionName
        )
      }
    </p>
  </div>

  <div data-pagefind-body class="mb-8">
    <div class="grid gap-8 md:grid-cols-3">
      <aside class="flex flex-col gap-8 h-full md:order-2">
        {
          entry.data.description ? (
            <AsideSection title="Descripción">
              <p class="text-sm text-foreground leading-relaxed">
                {entry.data.description}
              </p>
            </AsideSection>
          ) : null
        }
        <section class="space-y-3">
          <BarIndicator
            label="Tipo"
            value={degreeTypeLabels[entry.data.degreeType] ??
              entry.data.degreeType}
            total={4}
            filled={getDegreeTypeBarInfo(entry.data.degreeType).filled}
          />
          <BarIndicator
            label="Modalidad"
            value={modalityLabels[entry.data.modality] ?? entry.data.modality}
            total={3}
            filled={modalityBarFilled[entry.data.modality] ?? 1}
          />
        </section>
        <AsideSection title="Detalles">
          <KeyValueList items={detailItems} />
        </AsideSection>

        {
          solidarityFund.applies ? (
            <SolidarityFundInfo
              tier={solidarityFund.tier}
              additional={solidarityFund.additional}
            />
          ) : null
        }

        <AsideSection title="Contacto">
          <div class="flex flex-col gap-2">
            <a
              href={entry.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm inline-flex items-center justify-center gap-1"
            >
              Sitio web oficial
            </a>
            {
              entry.data.contactEmail ? (
                <button
                  type="button"
                  class="btn-outline"
                  data-copy={entry.data.contactEmail}
                >
                  {entry.data.contactEmail}
                </button>
              ) : null
            }
          </div>
        </AsideSection>

        <div class="flex justify-center">
          <a
            href={`https://github.com/GabrielDLeon/uruguay-laburos/edit/main/src/content/educacion/${entry.id}.mdx`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors"
          >
            <Icon name="mdi:pencil" class="size-3" />
            Editar contenido
          </a>
        </div>
      </aside>

      <div class="md:order-1 md:col-span-2 min-w-0">
        <div
          id="tabbed-content"
          class="prose prose-sm dark:prose-invert max-w-none"
        >
          <Content />
        </div>
      </div>
    </div>
    <span
      data-pagefind-meta={`degreeType:${degreeTypeLabels[entry.data.degreeType] ?? entry.data.degreeType}`}
    ></span>
    <span
      data-pagefind-meta={`modality:${modalityLabels[entry.data.modality] ?? entry.data.modality}`}
    ></span>
    <span data-pagefind-meta="kind:educacion"></span>
  </div>
</Layout>
