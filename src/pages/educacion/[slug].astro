---
import { getCollection, render } from "astro:content";

import { Icon } from "astro-icon/components";
import Layout from "@/layouts/Layout.astro";
import {
  degreeTypeLabels,
  modalityLabels,
  modalityBarFilled,
  getDegreeTypeBarInfo,
  formatDate,
  getSolidarityFundInfo,
} from "@/lib/educacion";
import SolidarityFundInfo from "@/components/SolidarityFundInfo.astro";
import BarIndicator from "@/components/BarIndicator.astro";

export async function getStaticPaths() {
  const entries = await getCollection(
    "educacion",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const solidarityFund = getSolidarityFundInfo(
  entry.data.institution,
  entry.data.duration,
);
---

<Layout
  title={entry.data.title}
  description={entry.data.description ??
    `${entry.data.degreeType} en ${entry.data.area} ofrecido por ${entry.data.institutionName}.`}
>
  <div class="mt-6 mb-4">
    <a
      href="/educacion"
      class="text-sm text-muted-foreground hover:text-foreground"
    >
      ← Volver a Educacion
    </a>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl mb-1 font-bold text-foreground sm:text-3xl">
      {entry.data.title}
    </h1>
    <p class="text-muted-foreground text-base">
      {
        entry.data.institution ? (
          <a
            href={`/educacion/instituciones/${entry.data.institution}`}
            class="hover:underline"
          >
            {entry.data.institutionName}
          </a>
        ) : (
          entry.data.institutionName
        )
      }
    </p>
  </div>

  <div data-pagefind-body class="mb-8">
    <div class="grid gap-8 md:grid-cols-3">
      <aside class="flex flex-col gap-8 h-full md:order-2">
        {
          entry.data.description ? (
            <section>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
                Descripción
              </h2>
              <hr class="border-[var(--border)] mt-2 mb-4" />
              <p class="text-sm text-foreground leading-relaxed">
                {entry.data.description}
              </p>
            </section>
          ) : null
        }
        <section class="space-y-3">
          <BarIndicator
            label="Tipo"
            value={degreeTypeLabels[entry.data.degreeType] ??
              entry.data.degreeType}
            total={4}
            filled={getDegreeTypeBarInfo(entry.data.degreeType).filled}
          />
          <BarIndicator
            label="Modalidad"
            value={modalityLabels[entry.data.modality] ?? entry.data.modality}
            total={3}
            filled={modalityBarFilled[entry.data.modality] ?? 1}
          />
        </section>
        <section>
          <h2
            class="text-xs font-semibold uppercase tracking-widest text-muted-foreground"
          >
            Detalles
          </h2>
          <hr class="border-[var(--border)] mt-2 mb-4" />
          <dl class="grid gap-2 text-sm">
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Área</dt>
              <dd class="font-medium text-right">{entry.data.area}</dd>
            </div>

            <div class="flex justify-between">
              <dt class="text-muted-foreground">Duración</dt>
              <dd class="font-medium text-right">{entry.data.duration}</dd>
            </div>
            {
              entry.data.credits ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Créditos</dt>
                  <dd class="font-medium text-right">{entry.data.credits}</dd>
                </div>
              ) : null
            }
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Costo</dt>
              <dd class="font-medium text-right">{entry.data.cost}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Idioma</dt>
              <dd class="font-medium text-right">{entry.data.language}</dd>
            </div>
            {
              entry.data.location ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Ubicación</dt>
                  <dd class="font-medium text-right">{entry.data.location}</dd>
                </div>
              ) : null
            }
            {
              entry.data.accreditation ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Acreditación</dt>
                  <dd class="font-medium text-right">
                    {entry.data.accreditation}
                  </dd>
                </div>
              ) : null
            }
            {
              entry.data.startDate ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Inicio</dt>
                  <dd class="font-medium text-right">
                    {formatDate(entry.data.startDate)}
                  </dd>
                </div>
              ) : null
            }
            {
              entry.data.applicationDeadline ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Cierre inscripción</dt>
                  <dd class="font-medium text-right">
                    {formatDate(entry.data.applicationDeadline)}
                  </dd>
                </div>
              ) : null
            }
          </dl>
        </section>

        {
          solidarityFund.applies ? (
            <SolidarityFundInfo
              tier={solidarityFund.tier}
              additional={solidarityFund.additional}
            />
          ) : null
        }

        <section>
          <h2
            class="text-xs font-semibold uppercase tracking-widest text-muted-foreground"
          >
            Contacto
          </h2>
          <hr class="border-[var(--border)] mt-2 mb-4" />
          <div class="flex flex-col gap-2">
            <a
              href={entry.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm inline-flex items-center justify-center gap-1"
            >
              Sitio web oficial
            </a>
            {
              entry.data.contactEmail ? (
                <button
                  type="button"
                  class="btn-outline"
                  data-copy={entry.data.contactEmail}
                >
                  {entry.data.contactEmail}
                </button>
              ) : null
            }
          </div>
        </section>

        <div class="flex justify-center">
          <a
            href={`https://github.com/GabrielDLeon/uruguay-laburos/edit/main/src/content/educacion/${entry.id}.mdx`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors"
          >
            <Icon name="mdi:pencil" class="size-3" />
            Editar contenido
          </a>
        </div>
      </aside>

      <div class="md:order-1 md:col-span-2 min-w-0">
        <div
          id="tabbed-content"
          class="prose prose-sm dark:prose-invert max-w-none"
        >
          <Content />
        </div>
      </div>
    </div>
    <span
      data-pagefind-meta={`degreeType:${degreeTypeLabels[entry.data.degreeType] ?? entry.data.degreeType}`}
    ></span>
    <span
      data-pagefind-meta={`modality:${modalityLabels[entry.data.modality] ?? entry.data.modality}`}
    ></span>
    <span data-pagefind-meta="kind:educacion"></span>
  </div>
</Layout>

<script>
  document.addEventListener("click", (e: MouseEvent) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const btn = target.closest("[data-copy]") as HTMLElement | null;
    if (btn) {
      navigator.clipboard.writeText(btn.dataset.copy ?? "");
      const original = btn.textContent;
      btn.textContent = "Copiado!";
      setTimeout(() => {
        btn.textContent = original;
      }, 2000);
    }
  });
</script>
