---
import { getCollection, render } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import { degreeTypeLabels, modalityLabels, formatDate } from "@/lib/educacion";

export async function getStaticPaths() {
  const entries = await getCollection("educacion");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={entry.data.title}
  description={`${entry.data.degreeType} en ${entry.data.area} ofrecido por ${entry.data.institution}.`}
>
  <section class="mb-8 pt-6 sm:pt-8">
    <div class="flex flex-wrap items-center gap-2 mb-3">
      <span class="badge-secondary">
        {degreeTypeLabels[entry.data.degreeType] ?? entry.data.degreeType}
      </span>
      <span class="badge-outline">
        {modalityLabels[entry.data.modality] ?? entry.data.modality}
      </span>
      {
        entry.data.isActive ? (
          <span class="badge-success">Inscripcion abierta</span>
        ) : (
          <span class="badge-destructive">Inscripcion cerrada</span>
        )
      }
    </div>

    <h1 class="text-2xl mb-2 font-extrabold text-foreground sm:text-3xl">
      {entry.data.title}
    </h1>
    <p class="text-muted-foreground text-base">{entry.data.institution}</p>
  </section>

  <section class="grid gap-6 md:grid-cols-3 mb-8">
    <div class="card p-4 md:col-span-2">
      <div class="prose prose-sm max-w-none">
        <Content />
      </div>
    </div>

    <aside class="flex flex-col gap-4">
      <div class="card p-4">
        <h2 class="text-sm font-semibold mb-3">Informacion general</h2>
        <dl class="grid gap-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Area</dt>
            <dd class="font-medium">{entry.data.area}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Duracion</dt>
            <dd class="font-medium">{entry.data.duration}</dd>
          </div>
          {
            entry.data.credits ? (
              <div class="flex justify-between">
                <dt class="text-muted-foreground">Creditos</dt>
                <dd class="font-medium">{entry.data.credits}</dd>
              </div>
            ) : null
          }
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Costo</dt>
            <dd class="font-medium">{entry.data.cost}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Idioma</dt>
            <dd class="font-medium">{entry.data.language}</dd>
          </div>
          {
            entry.data.location ? (
              <div class="flex justify-between">
                <dt class="text-muted-foreground">Ubicacion</dt>
                <dd class="font-medium">{entry.data.location}</dd>
              </div>
            ) : null
          }
          {
            entry.data.accreditation ? (
              <div class="flex justify-between">
                <dt class="text-muted-foreground">Acreditacion</dt>
                <dd class="font-medium">{entry.data.accreditation}</dd>
              </div>
            ) : null
          }
          {
            entry.data.startDate ? (
              <div class="flex justify-between">
                <dt class="text-muted-foreground">Inicio</dt>
                <dd class="font-medium">{formatDate(entry.data.startDate)}</dd>
              </div>
            ) : null
          }
          {
            entry.data.applicationDeadline ? (
              <div class="flex justify-between">
                <dt class="text-muted-foreground">Cierre inscripcion</dt>
                <dd class="font-medium">
                  {formatDate(entry.data.applicationDeadline)}
                </dd>
              </div>
            ) : null
          }
        </dl>
      </div>

      {
        entry.data.requirements.length > 0 ? (
          <div class="card p-4">
            <h2 class="text-sm font-semibold mb-3">Requisitos</h2>
            <ul class="list-inside list-disc text-sm text-muted-foreground">
              {entry.data.requirements.map((req) => (
                <li>{req}</li>
              ))}
            </ul>
          </div>
        ) : null
      }

      {
        entry.data.tags.length > 0 ? (
          <div class="card p-4">
            <h2 class="text-sm font-semibold mb-3">Etiquetas</h2>
            <div class="flex flex-wrap gap-1">
              {entry.data.tags.map((tag) => (
                <span class="badge-outline text-xs">{tag}</span>
              ))}
            </div>
          </div>
        ) : null
      }

      <div class="card p-4">
        <h2 class="text-sm font-semibold mb-3">Contacto</h2>
        <div class="flex flex-col gap-2">
          <a
            href={entry.data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm inline-flex items-center justify-center gap-1"
          >
            Sitio web oficial
          </a>
          {
            entry.data.contactEmail ? (
              <a
                href={`mailto:${entry.data.contactEmail}`}
                class="btn-outline btn-sm inline-flex items-center justify-center gap-1"
              >
                {entry.data.contactEmail}
              </a>
            ) : null
          }
        </div>
      </div>
    </aside>
  </section>

  <div class="mb-8">
    <a
      href="/educacion"
      class="text-sm text-muted-foreground hover:text-foreground"
    >
      ← Volver a Educacion
    </a>
  </div>
</Layout>
