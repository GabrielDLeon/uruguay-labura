---
import { getCollection, render } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import {
  degreeTypeLabels,
  modalityLabels,
  formatDate,
  getSolidarityFundInfo,
} from "@/lib/educacion";
import SolidarityFundInfo from "@/components/SolidarityFundInfo.astro";

export async function getStaticPaths() {
  const entries = await getCollection(
    "educacion",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const solidarityFund = getSolidarityFundInfo(
  entry.data.institution,
  entry.data.duration,
);
---

<Layout
  title={entry.data.title}
  description={entry.data.description ??
    `${entry.data.degreeType} en ${entry.data.area} ofrecido por ${entry.data.institutionName}.`}
>
  <div class="mt-6 mb-4">
    <a
      href="/educacion"
      class="text-sm text-muted-foreground hover:text-foreground"
    >
      ← Volver a Educacion
    </a>
  </div>

  <div data-pagefind-body class="mb-8">
    <div class="grid gap-8 md:grid-cols-3">
      <div class="md:col-span-2 min-w-0">
        <div class="mb-6">
          <h1
            class="font-playfair text-2xl mb-1 font-extrabold text-foreground sm:text-3xl"
          >
            {entry.data.title}
          </h1>
          <p class="text-muted-foreground text-base">
            {
              entry.data.institution ? (
                <a
                  href={`/educacion/instituciones/${entry.data.institution}`}
                  class="hover:underline"
                >
                  {entry.data.institutionName}
                </a>
              ) : (
                entry.data.institutionName
              )
            }
          </p>
        </div>

        <div class="prose prose-sm dark:prose-invert max-w-none">
          <Content />
        </div>
      </div>

      <aside class="flex flex-col gap-8 h-full">
        {
          entry.data.description ? (
            <section>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
                Descripcion
              </h2>
              <hr class="border-[var(--border)] mt-2 mb-4" />
              <p class="text-sm text-foreground leading-relaxed">
                {entry.data.description}
              </p>
            </section>
          ) : null
        }
        <section>
          <h2
            class="text-xs font-semibold uppercase tracking-widest text-muted-foreground"
          >
            Detalles
          </h2>
          <hr class="border-[var(--border)] mt-2 mb-4" />
          <dl class="grid gap-2 text-sm">
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Area</dt>
              <dd class="font-medium text-right">{entry.data.area}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Tipo</dt>
              <dd class="font-medium text-right">
                {
                  degreeTypeLabels[entry.data.degreeType] ??
                    entry.data.degreeType
                }
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Modalidad</dt>
              <dd class="font-medium text-right">
                {modalityLabels[entry.data.modality] ?? entry.data.modality}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Duracion</dt>
              <dd class="font-medium text-right">{entry.data.duration}</dd>
            </div>
            {
              entry.data.credits ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Creditos</dt>
                  <dd class="font-medium text-right">{entry.data.credits}</dd>
                </div>
              ) : null
            }
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Costo</dt>
              <dd class="font-medium text-right">{entry.data.cost}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-muted-foreground">Idioma</dt>
              <dd class="font-medium text-right">{entry.data.language}</dd>
            </div>
            {
              entry.data.location ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Ubicacion</dt>
                  <dd class="font-medium text-right">{entry.data.location}</dd>
                </div>
              ) : null
            }
            {
              entry.data.accreditation ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Acreditacion</dt>
                  <dd class="font-medium text-right">
                    {entry.data.accreditation}
                  </dd>
                </div>
              ) : null
            }
            {
              entry.data.startDate ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Inicio</dt>
                  <dd class="font-medium text-right">
                    {formatDate(entry.data.startDate)}
                  </dd>
                </div>
              ) : null
            }
            {
              entry.data.applicationDeadline ? (
                <div class="flex justify-between">
                  <dt class="text-muted-foreground">Cierre inscripcion</dt>
                  <dd class="font-medium text-right">
                    {formatDate(entry.data.applicationDeadline)}
                  </dd>
                </div>
              ) : null
            }
          </dl>
        </section>

        {
          entry.data.requirements.length > 0 ? (
            <section>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
                Requisitos
              </h2>
              <hr class="border-[var(--border)] mt-2 mb-4" />
              <ul class="list-inside list-disc text-sm text-muted-foreground space-y-1">
                {entry.data.requirements.map((req) => (
                  <li>{req}</li>
                ))}
              </ul>
            </section>
          ) : null
        }

        {
          solidarityFund.applies ? (
            <SolidarityFundInfo
              tier={solidarityFund.tier}
              additional={solidarityFund.additional}
            />
          ) : null
        }

        {
          entry.data.tags.length > 0 ? (
            <section>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">
                Etiquetas
              </h2>
              <hr class="border-[var(--border)] mt-2 mb-4" />
              <div class="flex flex-wrap gap-1">
                {entry.data.tags.map((tag) => (
                  <span class="badge-outline text-xs">{tag}</span>
                ))}
              </div>
            </section>
          ) : null
        }

        <section>
          <h2
            class="text-xs font-semibold uppercase tracking-widest text-muted-foreground"
          >
            Contacto
          </h2>
          <hr class="border-[var(--border)] mt-2 mb-4" />
          <div class="flex flex-col gap-2">
            <a
              href={entry.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm inline-flex items-center justify-center gap-1"
            >
              Sitio web oficial
            </a>
            {
              entry.data.contactEmail ? (
                <button
                  type="button"
                  class="btn-outline"
                  data-copy={entry.data.contactEmail}
                >
                  {entry.data.contactEmail}
                </button>
              ) : null
            }
          </div>
        </section>
      </aside>
    </div>
    <span
      data-pagefind-meta={`degreeType:${degreeTypeLabels[entry.data.degreeType] ?? entry.data.degreeType}`}
    ></span>
    <span
      data-pagefind-meta={`modality:${modalityLabels[entry.data.modality] ?? entry.data.modality}`}
    ></span>
    <span data-pagefind-meta="kind:educacion"></span>
  </div>
</Layout>

<script>
  document.addEventListener("click", (e: MouseEvent) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const btn = target.closest("[data-copy]") as HTMLElement | null;
    if (btn) {
      navigator.clipboard.writeText(btn.dataset.copy ?? "");
      const original = btn.textContent;
      btn.textContent = "Copiado!";
      setTimeout(() => {
        btn.textContent = original;
      }, 2000);
    }
  });
</script>
