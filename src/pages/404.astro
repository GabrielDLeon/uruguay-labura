---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Pagina no encontrada"
  description="La pagina que estabas buscando no existe"
>
  <div
    class="rounded-xl border border-[var(--border-subtle)] bg-[var(--card-bg)] p-6"
  >
    <h2 class="font-playfair text-2xl font-bold text-[var(--color-foreground)]">Error 404</h2>
    <p class="mt-2 text-[var(--color-muted-foreground)]">No encontramos la pagina solicitada.</p>
  </div>
</Layout>
