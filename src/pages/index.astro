---
import JobsExplorer from "@/components/jobs/JobsExplorer";
import { parseJobsDataset } from "@/lib/jobs-schema";
import Layout from "@/layouts/Layout.astro";
import jobsDatasetRaw from "@/data/jobs.generated.json";

const dataset = parseJobsDataset(jobsDatasetRaw);

const parsedScrapedAt = new Date(dataset.scrapedAt);
const formattedScrapedAt = Number.isNaN(parsedScrapedAt.getTime())
  ? dataset.scrapedAt
  : new Intl.DateTimeFormat("es-UY", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    }).format(parsedScrapedAt);
---

<Layout
  title="Llamados laborales en Uruguay"
  description="Explora llamados abiertos de Uruguay Concursa con filtros y vista centralizada."
>
  <section class="mb-8 pt-6 sm:pt-8">
    <p
      class="text-xs font-semibold uppercase tracking-[0.14em] text-muted-foreground"
    >
      Actualizado: {formattedScrapedAt}
    </p>
    <h1 class="text-2xl mb-2 font-extrabold text-foreground sm:text-3xl">
      Llamados laborales de Uruguay
    </h1>
    <p class="max-w-3xl text-sm sm:text-base text-muted-foreground">
      El siguiente listado es una recopilación semanal de los concursos
      actualmente disponibles y activos del sitio
      <a
        href="https://www.uruguayconcursa.gub.uy"
        target="_blank"
        rel="noopener noreferrer"
        class="underline decoration-dotted underline-offset-3 hover:text-foreground"
        >Uruguay Concursa</a
      >. El proyecto busca mejorar la experiencia de los usuarios.
    </p>
  </section>

  <JobsExplorer client:load jobs={dataset.jobs} />
</Layout>
